  "corrector_normalization": {
    "enabled": true,
    "root_joint": 0,
    "scale_mode": "stable_bones",
    "eps": 0.000001
  },
  "training": {
    "epochs": 0,
    "batch_size": 8,
    "device": "auto"
  },
  "visualization": {
    "enabled": false
  }
}
